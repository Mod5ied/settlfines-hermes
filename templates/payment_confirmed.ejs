<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment confirmed — PCN <%= pcn_number %></title>
</head>

<body style="margin:0; padding:0; background-color:#f8fafc; font-family:system-ui, -apple-system, sans-serif;">
  <div style="background-color:#f8fafc; padding:40px 20px;">
    <div style="max-width:600px; margin:0 auto; background-color:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 4px 6px rgba(0,0,0,0.05);">

      <!-- Header -->
      <div style="background:#1C1917; padding:32px 24px; text-align:center;">
        <img
          src="data:image/png;base64,"
          alt="Settlfines" width="200" height="33" style="display:block; margin:0 auto;" />
      </div>

      <!-- Result Badge -->
      <div style="padding:28px 24px 0; text-align:center;">
        <div style="display:inline-block; background-color:#eff6ff; border:1px solid #93c5fd; border-radius:20px; padding:8px 20px;">
          <span style="color:#1e3a8a; font-size:14px; font-weight:600;">Payment Confirmed</span>
        </div>
      </div>

      <!-- Main Content -->
      <div style="padding:28px 32px;">
        <h2 style="font-size:22px; font-weight:700; color:#111827; margin-bottom:12px;">
          Hi <%= user_name %>,
        </h2>

        <p style="font-size:16px; line-height:1.7; color:#374151; margin-bottom:8px;">
          Your PCN payment has been processed and confirmed. This matter is now fully closed.
        </p>

        <p style="font-size:16px; line-height:1.7; color:#374151; margin-bottom:24px;">
          Please keep this email as proof of payment should you receive any further correspondence.
        </p>

        <!-- Payment Receipt Card -->
        <div style="background-color:#f0f7ff; border:2px solid #93c5fd; border-radius:10px; padding:20px; margin-bottom:28px;">
          <p style="margin:0 0 6px; font-size:13px; color:#1e40af; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Payment Receipt</p>
          <p style="margin:0 0 20px; font-size:20px; color:#1e3a8a; font-weight:700;"><%= pcn_number %></p>

          <div style="border-top:1px solid #bfdbfe; padding-top:16px;">
            <table style="width:100%; border-collapse:collapse;">
              <tbody>
                <tr>
                  <td style="padding:7px 0; font-size:14px; color:#1e40af;">Operator</td>
                  <td style="padding:7px 0; font-size:14px; color:#111827; font-weight:600; text-align:right;"><%= operator_name %></td>
                </tr>
                <tr>
                  <td style="padding:7px 0; font-size:14px; color:#1e40af;">Payment Reference</td>
                  <td style="padding:7px 0; font-size:14px; color:#111827; font-weight:600; text-align:right;"><%= payment_reference %></td>
                </tr>
                <tr>
                  <td style="padding:7px 0; font-size:14px; color:#1e40af;">Payment Date</td>
                  <td style="padding:7px 0; font-size:14px; color:#111827; font-weight:600; text-align:right;"><%= payment_date %></td>
                </tr>
                <tr>
                  <td style="padding:7px 0; font-size:15px; color:#1e3a8a; font-weight:700;">Amount Paid</td>
                  <td style="padding:7px 0; font-size:15px; color:#1e3a8a; font-weight:700; text-align:right;"><%= full_penalty_amount %></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Closing note -->
        <p style="font-size:15px; line-height:1.7; color:#374151; margin-bottom:8px;">
          If you believe this payment was made in error or you have questions about this transaction, reply to this email and our team will look into it promptly.
        </p>

        <p style="font-size:15px; line-height:1.7; color:#374151; margin-bottom:28px;">
          Thank you for using Settlfines.
        </p>

        <!-- CTA -->
        <div style="text-align:center; margin-top:32px;">
          <a href="<%= cta_url %>"
            style="display:inline-block; background-color:#FF6900; color:#ffffff; font-size:15px; font-weight:600; padding:14px 32px; border-radius:10px; text-decoration:none;">
            View Payment Record
          </a>
        </div>
      </div>

      <!-- Footer -->
      <div style="background-color:#f9fafb; padding:24px 32px; border-top:1px solid #e5e7eb;">
        <p style="margin:0 0 8px; font-size:13px; color:#6b7280; text-align:center;">
          Settlfines — automated parking fine dispute platform
        </p>
        <p style="margin:0; font-size:12px; color:#9ca3af; text-align:center;">
          &copy; 2026 Settlfines Ltd. This is a system-generated notification.
        </p>
      </div>

    </div>
  </div>
</body>
</html>
