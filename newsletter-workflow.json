      "parameters": {
        "jsCode": "const tid = $input.first().json.query.tid || '';\nlet emailId = '', subscriberEmail = '';\ntry { const d = Buffer.from(tid, 'base64url').toString(); const p = d.split('-'); if (p.length >= 3) { emailId = p[0]; subscriberEmail = p.slice(1,-1).join('-'); } } catch(e) {}\nreturn [{ json: { trackingId: tid, emailId, subscriberEmail, eventType: 'open', timestamp: new Date().toISOString() } }];"
      },
