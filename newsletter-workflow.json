    {
      "parameters": {
        "jsCode": "const ejs = require('ejs');\n\n// Get template from Postgres result\nconst templateRow = $('Fetch Template from Postgres').first().json;\nconst ejsTemplate = templateRow.template;\nconst ejsSubject = templateRow.subject;\n\n// Get payload from the original webhook body\nconst webhookData = $('Webapp Webhook').first().json;\nconst payload = webhookData.body.payload || {};\n\n// Render EJS with payload data\nconst renderedBody = ejs.render(ejsTemplate, payload);\nconst renderedSubject = ejs.render(ejsSubject, payload);\n\n// Recipient must be in the payload\nconst to = payload.to || payload.email || '';\nif (!to) throw new Error('Missing \"to\" or \"email\" in payload');\n\nreturn [{\n  json: {\n    to,\n    subject: renderedSubject,\n    htmlBody: renderedBody,\n    operation: webhookData.body.operation,\n    templateName: templateRow.name\n  }\n}];"
      },
