    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst emailData = $('get email').first().json;\nconst N8N_WEBHOOK_BASE_URL = 'YOUR_N8N_WEBHOOK_URL';\nconst results = [];\nfor (const item of items) {\n  const subscriberEmail = item.json.Email;\n  const subscriberName = item.json.Name || '';\n  const emailId = emailData['Email ID'];\n  const trackingId = Buffer.from(`${emailId}-${subscriberEmail}-${Date.now()}`).toString('base64url');\n  let htmlBody = emailData['HTML Body'] || emailData['Body'] || '';\n  htmlBody = htmlBody.replace(/href=\"(https?:\\/\\/[^\"]+)\"/gi, (match, url) => {\n    return `href=\"${N8N_WEBHOOK_BASE_URL}/track-click?tid=${trackingId}&url=${encodeURIComponent(url)}\"`;\n  });\n  const pixel = `<img src=\"${N8N_WEBHOOK_BASE_URL}/track-open?tid=${trackingId}\" width=\"1\" height=\"1\" style=\"display:none;\" />`;\n  htmlBody = htmlBody.includes('</body>') ? htmlBody.replace('</body>', `${pixel}</body>`) : htmlBody + pixel;\n  const unsub = `<div style=\"margin-top:30px;padding-top:15px;border-top:1px solid #eee;text-align:center;font-size:12px;color:#999;\"><p><a href=\"${N8N_WEBHOOK_BASE_URL}/unsubscribe?email=${encodeURIComponent(subscriberEmail)}\" style=\"color:#999;\">Unsubscribe</a></p></div>`;\n  htmlBody = htmlBody.includes('</body>') ? htmlBody.replace('</body>', `${unsub}</body>`) : htmlBody + unsub;\n  htmlBody = htmlBody.replace(/\\{\\{name\\}\\}/gi, subscriberName);\n  results.push({ json: { to: subscriberEmail, subject: emailData['Subject'], htmlBody } });\n}\nreturn results;"
      },
